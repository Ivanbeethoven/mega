# Orion Runner 生产环境变量
# 由 systemd EnvironmentFile 加载

# Buck2 项目根目录（scorpiofs 挂载点）
BUCK_PROJECT_ROOT="/workspace/mount"

# Orion Server WebSocket 地址
SERVER_WS="wss://orion.gitmega.com/ws"

# 默认日志级别，并屏蔽 rfuse3 的 4096-byte alignment 噪声警告
RUST_LOG="info,rfuse3::raw::session=error"

# 单次领取任务数
SELECT_TASK_COUNT="30"

# 初始轮询间隔（秒）
INITIAL_POLL_INTERVAL_SECS="2"
